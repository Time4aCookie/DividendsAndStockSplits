# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Gmail (or Outlook) sender account
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here

# Five recipients (comma-separated, no spaces around commas)
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com,recipient3@example.com,recipient4@example.com,recipient5@example.com
