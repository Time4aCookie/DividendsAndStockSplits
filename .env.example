# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Outlook sender account
EMAIL_SENDER=rohant@jagtradingllc.com
EMAIL_PASSWORD=your_outlook_app_password_here

# Five recipients (comma-separated, no spaces around commas)
EMAIL_RECIPIENTS=recipient1@jagtradingllc.com,recipient2@jagtradingllc.com,recipient3@jagtradingllc.com,recipient4@jagtradingllc.com,recipient5@jagtradingllc.com
